{
    "name": "masterro/laravel-access-screen",
    "description": "Provides a configurable password screen for your Laravel application.",
    "type": "library",
    "authors": [
        {
            "name": "Roman Ihoshyn",
            "email": "igoshin18@gmail.com"
        }
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2|^8.3|^8.4|^8.5",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0|^5.0"
    },
    "autoload": {
        "psr-4": {
            "MasterRO\\AccessScreen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MasterRO\\AccessScreen\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MasterRO\\AccessScreen\\AccessScreenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
